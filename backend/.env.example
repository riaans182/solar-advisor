# Solar Advisor configuration. Copy to `.env` (`cp .env.example .env`) and edit.
# Only SA_MQTT_HOST and ANTHROPIC_API_KEY are required by docker-compose; the
# rest fall back to the defaults shown here. Full reference: README.md.

# ── Required ──────────────────────────────────────────────────────────────────
# Your SolarAssistant / MQTT broker host (read-only). Must be reachable on the LAN.
SA_MQTT_HOST=192.168.1.10
# Claude API key for the Explain panel. docker-compose requires this to be set
# even when Explain is disabled — use any non-empty placeholder if you don't use it.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── MQTT (optional) ───────────────────────────────────────────────────────────
SA_MQTT_PORT=1883
SA_MQTT_USER=
SA_MQTT_PASS=

# ── Tariff ────────────────────────────────────────────────────────────────────
# Fallback marginal rate (used until enough logged purchases exist to derive one).
SA_TARIFF_RATE=3.56
SA_TARIFF_FIXED_CHARGE=600

# ── Battery / inverter ────────────────────────────────────────────────────────
# Grid-charge power cap (many inverters cap grid charging below full charge power).
SA_MAX_GRID_CHARGE_POWER_W=3640

# ── Solar forecast ────────────────────────────────────────────────────────────
# `static` uses a fixed estimate; `forecast_solar` fetches a real per-plane forecast.
SA_FORECAST_SOURCE=static
SA_LAT=-33.92
SA_LON=18.42
# JSON list of PV planes for forecast_solar, e.g. [{"tilt":20,"azimuth":-135,"kwp":2.5}]
SA_PV_ARRAYS=
SA_FORECAST_TTL_S=10800
SA_TIMEZONE=Africa/Johannesburg

# ── Explain (LLM) ─────────────────────────────────────────────────────────────
SA_EXPLAIN_ENABLED=true
SA_EXPLAIN_MODEL=claude-haiku-4-5

# ── Retention ─────────────────────────────────────────────────────────────────
# Telemetry older than this many days is pruned (purchases are never pruned).
SA_TELEMETRY_RETENTION_DAYS=90
